{
  "expo": {
    "name": "Questia",
    "slug": "questia",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "questia",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a0f"
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#22d3ee"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Questia utilise ta localisation pour vérifier la sécurité de tes quêtes."
        }
      ],
      [
        "@clerk/expo",
        {
          "scheme": "questia"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Questia accède à tes photos pour composer ta carte à partager.",
          "cameraPermission": "Questia utilise l’appareil photo pour ta carte à partager."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
