{
  "expo": {
    "name": "Questia",
    "slug": "questia",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "questia",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "bundleIdentifier": "fr.questia.app",
      "associatedDomains": [
        "applinks:questia.fr"
      ]
    },
    "android": {
      "package": "fr.questia.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "questia.fr",
              "pathPrefix": "/app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "ea564bf1-e208-44c6-b54b-5ee1fba40095"
      },
      "router": {}
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#22d3ee"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Questia utilise ta localisation pour vérifier la sécurité de tes quêtes."
        }
      ],
      [
        "@clerk/expo",
        {
          "scheme": "questia"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Questia accède à tes photos pour composer ta carte à partager.",
          "cameraPermission": "Questia utilise l’appareil photo pour ta carte à partager."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "souprojet"
  }
}
