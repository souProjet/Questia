{
  "expo": {
    "name": "Dopamode",
    "slug": "dopamode",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dopamode",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a0f"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Dopamode utilise ta localisation pour vérifier la sécurité de tes quêtes."
        }
      ],
      [
        "@clerk/expo",
        {
          "scheme": "dopamode"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
