# Option A — automatique : si `credentials.json` (apps/mobile ou racine du monorepo) contient
# `android.keystore` (format EAS : keystorePath, mots de passe, alias), le prebuild génère
# `android/keystore.properties` tout seul. Ne versionne jamais credentials.json ni le .jks.
#
# Option B — manuel : copie ce modèle vers android/keystore.properties après prebuild.
# Chemins dans storeFile : relatifs au dossier android/ (ex. ../credentials/android/keystore.jks).
#
# Vérifie l’empreinte SHA1 (doit matcher Play Console) :
#   keytool -list -v -keystore credentials/android/keystore.jks -alias TON_ALIAS

storePassword=********
keyPassword=********
keyAlias=upload
storeFile=../credentials/android/keystore.jks
