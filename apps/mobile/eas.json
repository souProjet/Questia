{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "node": "20.19.0",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "node": "20.19.0",
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://questia.fr",
        "EXPO_PUBLIC_SITE_URL": "https://questia.fr"
      }
    },
    "production": {
      "node": "20.19.0",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://questia.fr",
        "EXPO_PUBLIC_SITE_URL": "https://questia.fr"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "your@email.com",
        "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json"
      }
    }
  }
}
