# ──────────────────────────────────────────────────────────────
# Projet — https://github.com/souProjet/Questia
# ──────────────────────────────────────────────────────────────
# Clerk — https://dashboard.clerk.com
# Utilise la MÊME clé publishable que le web (préfixe EXPO_PUBLIC_)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────
# URL de l'API backend (Next.js)
# • Simulateur: http://localhost:3000
# • Téléphone: IP de ton PC (ex: http://192.168.1.10:3000) — lance npm run dev:web
# • Production: https://ton-domaine.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Expo Push (EAS) — https://docs.expo.dev/push-notifications/push-notifications-setup/
# Renseigne l’UUID du projet (`eas project:info`) ou mets le même id dans app.json > extra.eas.projectId
# EXPO_PUBLIC_EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optionnel : origine du site Next.js si différente de l’API (sinon la boutique utilise EXPO_PUBLIC_API_BASE_URL)
# EXPO_PUBLIC_WEB_BASE_URL=https://ton-domaine.com
