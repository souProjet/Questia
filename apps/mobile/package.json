{
  "name": "@questia/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "expo": {
    "autolinking": {
      "searchPaths": ["../../node_modules", "./node_modules"]
    }
  },
  "scripts": {
    "eas-build-pre-install": "node ../../scripts/eas-assert-expo-public-clerk.mjs",
    "dev": "expo start",
    "dev:tunnel": "expo start --tunnel",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "android": "expo run:android",
    "android:bundle": "bash ../../scripts/android-bundle-release.sh",
    "android:assemble:win": "powershell -ExecutionPolicy Bypass -NoProfile -File ../../scripts/win-android-assemble.ps1",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@clerk/expo": "^3.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@questia/shared": "*",
    "@questia/ui": "*",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "expo": "~54.0.0",
    "expo-auth-session": "~6.0.0",
    "expo-constants": "~18.0.0",
    "expo-crypto": "~14.0.0",
    "expo-device": "~8.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.0",
    "expo-location": "~19.0.0",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.0",
    "expo-web-browser": "~14.0.0",
    "is-arrayish": "^0.3.4",
    "posthog-react-native": "^4.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "solito": "^4.3.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "@types/react-native": "~0.73.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.8.0"
  }
}
