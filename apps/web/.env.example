# ──────────────────────────────────────────────────────────────
# NeonDB (Prisma)
# DATABASE_URL = URL du pooler (PgBouncer) pour les requêtes runtime
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.neon.tech/dopamode?sslmode=require&channel_binding=require
# DIRECT_DATABASE_URL = URL directe (sans pooler) pour les migrations Prisma
DIRECT_DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/dopamode?sslmode=require

# ──────────────────────────────────────────────────────────────
# Clerk — https://dashboard.clerk.com
# Récupère ces clés dans ton dashboard Clerk > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Routes de redirection après auth
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ──────────────────────────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=your_openai_api_key

# ──────────────────────────────────────────────────────────────
# OpenWeatherMap
OPENWEATHER_API_KEY=your_openweather_api_key
