# ──────────────────────────────────────────────────────────────
# Projet — https://github.com/souProjet/Questia
# Après renommage Neon / Clerk : mets à jour les URLs ci-dessous et les
# « Authorized redirect URLs » + domaines dans le dashboard Clerk.
# ──────────────────────────────────────────────────────────────
# NeonDB (Prisma)
# DATABASE_URL = URL du pooler (PgBouncer) pour les requêtes runtime
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.neon.tech/questia?sslmode=require&channel_binding=require
# DIRECT_DATABASE_URL = URL directe (sans pooler) pour les migrations Prisma
DIRECT_DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/questia?sslmode=require

# ──────────────────────────────────────────────────────────────
# Clerk — https://dashboard.clerk.com
# Récupère ces clés dans ton dashboard Clerk > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Routes de redirection après auth
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# ──────────────────────────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=your_openai_api_key
# Modèle pour les quêtes quotidiennes et la narration (défaut : gpt-4o-mini)
# OPENAI_MODEL=gpt-4o

# ──────────────────────────────────────────────────────────────
# OpenWeatherMap
OPENWEATHER_API_KEY=your_openweather_api_key

# ──────────────────────────────────────────────────────────────
# Stripe — uniquement pour recharger des « Quest Coins » (monnaie virtuelle).
# Les thèmes / packs / relances s’achètent en QC dans l’app (pas d’euro direct).
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# Webhook signing secret (Stripe CLI : stripe listen --forward-to localhost:3000/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ──────────────────────────────────────────────────────────────
# Rappels quête du jour (cron Vercel + push Expo + e-mail Resend)
# CRON_SECRET — même valeur que l’en-tête Authorization: Bearer … sur /api/cron/daily-reminders
CRON_SECRET=
# Resend — https://resend.com (optionnel : sans clé, seuls les push mobiles partent)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Questia <onboarding@resend.dev>

# ──────────────────────────────────────────────────────────────
# Identité légale (pages /legal/* — mentions, confidentialité, stores)
# Renseigner en prod pour remplacer les mentions [À compléter] sur le site.
# NEXT_PUBLIC_LEGAL_COMPANY_NAME=…
# NEXT_PUBLIC_LEGAL_FORM=SAS
# NEXT_PUBLIC_LEGAL_ADDRESS=…
# NEXT_PUBLIC_LEGAL_SIRET=…
# NEXT_PUBLIC_LEGAL_RCS=RCS Paris …
# NEXT_PUBLIC_LEGAL_VAT=…
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=contact@questia.fr
# NEXT_PUBLIC_LEGAL_DPO_EMAIL=…
# NEXT_PUBLIC_LEGAL_DIRECTOR=…
# Hébergeur (défaut Vercel si non défini)
# NEXT_PUBLIC_LEGAL_HOST_NAME=
# NEXT_PUBLIC_LEGAL_HOST_ADDRESS=
# NEXT_PUBLIC_LEGAL_HOST_WEBSITE=

# ──────────────────────────────────────────────────────────────
# Site & stores (SEO, liens App / Play sur la landing)
# URL canonique du site (sans slash final) — ex. https://questia.fr
NEXT_PUBLIC_SITE_URL=https://questia.fr
# Liens publics des fiches store (laisser vide tant que l’app n’est pas publiée)
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# ──────────────────────────────────────────────────────────────
# Marketing & analytics (opt-in via bandeau cookies — voir docs/marketing-analytics.md)
# Laisser vide tant que les comptes ne sont pas créés ; ne pas committer de vraies clés.
# Google Tag Manager (conteneur Web) — ex. GTM-XXXXXXX
# NEXT_PUBLIC_GTM_ID=
# Google Analytics 4 — uniquement si GA est branché EN DIRECT sans GTM (éviter doublon avec GTM)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Meta (Facebook) Pixel — ID numérique
# NEXT_PUBLIC_META_PIXEL_ID=
