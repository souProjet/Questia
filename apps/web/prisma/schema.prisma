generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum ExplorerAxis {
  homebody
  explorer
}

enum RiskAxis {
  cautious
  risktaker
}

enum EscalationPhase {
  calibration
  expansion
  rupture
}

enum QuestStatus {
  pending
  accepted
  completed
  rejected
  replaced
}

model Profile {
  id                    String          @id @default(cuid())
  clerkId               String          @unique @map("clerk_id")
  explorerAxis          ExplorerAxis    @map("explorer_axis")
  riskAxis              RiskAxis        @map("risk_axis")
  declaredPersonality   Json            @map("declared_personality")
  exhibitedPersonality  Json            @default("{}") @map("exhibited_personality")
  currentDay            Int             @default(1) @map("current_day")
  currentPhase          EscalationPhase @default(calibration) @map("current_phase")
  congruenceDelta       Float           @default(0) @map("congruence_delta")
  streakCount           Int             @default(0) @map("streak_count")
  rerollsRemaining      Int             @default(1) @map("rerolls_remaining")
  lastQuestDate         String?         @map("last_quest_date")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  questLogs QuestLog[]

  @@map("profiles")
}

model QuestLog {
  id          String      @id @default(cuid())
  profileId   String      @map("profile_id")
  questDate   String      @map("quest_date") // YYYY-MM-DD

  // Archetype reference
  archetypeId Int         @default(1) @map("archetype_id")

  // AI-generated content (unique per user per day)
  generatedEmoji      String   @default("⚔️") @map("generated_emoji")
  generatedTitle      String   @default("") @map("generated_title")
  generatedMission    String   @default("") @map("generated_mission") @db.Text
  generatedHook       String   @default("") @map("generated_hook")
  generatedDuration   String   @default("") @map("generated_duration")
  generatedSafetyNote String?  @map("generated_safety_note")
  isOutdoor           Boolean  @default(false) @map("is_outdoor")

  // Lieu suggéré (extérieur) — géocodage au moment de la génération
  destinationLabel    String?  @map("destination_label")
  destinationLat        Float?   @map("destination_lat")
  destinationLon      Float?   @map("destination_lon")

  // Context at generation time
  locationCity        String?  @map("location_city")
  weatherDescription  String?  @map("weather_description")
  weatherTemp         Float?   @map("weather_temp")

  // Status
  status            QuestStatus     @default(pending)
  completedAt       DateTime?       @map("completed_at")
  safetyConsentGiven Boolean        @default(false) @map("safety_consent_given")
  wasRerolled       Boolean         @default(false) @map("was_rerolled")
  wasFallback       Boolean         @default(false) @map("was_fallback")

  // Snapshot of profile state at quest time
  phaseAtAssignment     EscalationPhase @default(calibration) @map("phase_at_assignment")
  congruenceDeltaAtTime Float           @default(0) @map("congruence_delta_at_time")

  assignedAt DateTime @default(now()) @map("assigned_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, questDate])
  @@index([profileId])
  @@index([questDate])
  @@map("quest_logs")
}
