generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum ExplorerAxis {
  homebody
  explorer
}

enum RiskAxis {
  cautious
  risktaker
}

enum EscalationPhase {
  calibration
  expansion
  rupture
}

enum QuestStatus {
  pending
  accepted
  completed
  rejected
  replaced
  abandoned
}

enum UserRole {
  user
  admin
}

enum QuestPsychologicalCategory {
  spatial_adventure
  public_introspection
  sensory_deprivation
  exploratory_sociability
  physical_existential
  async_discipline
  dopamine_detox
  active_empathy
  temporal_projection
  hostile_immersion
  spontaneous_altruism
  relational_vulnerability
  unconditional_service
}

enum QuestComfortLevel {
  low
  moderate
  high
  extreme
}

enum QuestArchetypePace {
  instant
  planned
}

/** Taxonomie des archétypes (source unique côté produit — plus de liste en dur dans le code). */
model QuestArchetype {
  id                     Int                       @id
  title                  String
  description            String                    @db.Text
  titleEn                String                    @map("title_en")
  descriptionEn          String                    @db.Text @map("description_en")
  category               QuestPsychologicalCategory
  targetTraits           Json                      @map("target_traits")
  comfortLevel           QuestComfortLevel         @map("comfort_level")
  requiresOutdoor        Boolean                   @map("requires_outdoor")
  requiresSocial         Boolean                   @map("requires_social")
  minimumDurationMinutes Int                       @map("minimum_duration_minutes")
  fallbackQuestId        Int?                      @map("fallback_quest_id")
  questPace              QuestArchetypePace        @map("quest_pace")
  published              Boolean                   @default(true)
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")

  @@map("quest_archetypes")
}

/** Clés de configuration applicative (ex. fallback archetype id). */
model AppSetting {
  key   String @id
  value String @db.Text

  @@map("app_settings")
}

model Profile {
  id                    String          @id @default(cuid())
  clerkId               String          @unique @map("clerk_id")
  role                  UserRole        @default(user) @map("role")
  explorerAxis          ExplorerAxis    @map("explorer_axis")
  riskAxis              RiskAxis        @map("risk_axis")
  /** 3e question onboarding (optionnelle) — null si skippée */
  sociability           String?         @map("sociability")
  declaredPersonality   Json            @map("declared_personality")
  exhibitedPersonality  Json            @default("{}") @map("exhibited_personality")
  currentDay            Int             @default(1) @map("current_day")
  currentPhase          EscalationPhase @default(calibration) @map("current_phase")
  congruenceDelta       Float           @default(0) @map("congruence_delta")
  streakCount           Int             @default(0) @map("streak_count")
  rerollsRemaining      Int             @default(1) @map("rerolls_remaining")
  /** Relances achetées, utilisables quand la relance du jour est épuisée */
  bonusRerollCredits    Int             @default(0) @map("bonus_reroll_credits")
  lastQuestDate         String?         @map("last_quest_date")
  totalXp               Int             @default(0) @map("total_xp")
  badgesEarned          Json            @default("[]") @map("badges_earned")
  flagNextQuestAfterReroll Boolean      @default(false) @map("flag_next_quest_after_reroll")
  /** Archétype à exclure à la prochaine génération (après relance / report — évite de retomber sur la même quête). */
  rerollExcludeArchetypeId Int?          @map("reroll_exclude_archetype_id")
  /** Archétypes déjà proposés dans la journée (relances successives) — cumul jusqu'à la prochaine quête enregistrée. JSON number[]. */
  rerollExcludeArchetypeIds Json         @default("[]") @map("reroll_exclude_archetype_ids")
  /** Après « Reporter » : la prochaine génération impose un archétype instantané */
  flagNextQuestInstantOnly Boolean      @default(false) @map("flag_next_quest_instant_only")
  /** Date (YYYY-MM-DD) choisie pour reprendre une quête plus lourde / sociale — rappel UX */
  deferredSocialUntil   String?         @map("deferred_social_until")
  /** Thème UI actif : default | midnight | aurora | parchment */
  activeThemeId         String          @default("default") @map("active_theme_id")
  /** Liste des ids de thèmes possédés (JSON string[]) */
  ownedThemes           Json            @default("[\"default\"]") @map("owned_themes")
  /** Monnaie virtuelle (Quest Coins) — recharge via Stripe (packs) uniquement */
  coinBalance           Int             @default(0) @map("coin_balance")
  /** Titres boutique débloqués (JSON string[] — ids TITLES_REGISTRY) */
  ownedTitleIds         Json            @default("[]") @map("owned_title_ids")
  /** Titre affiché sous le pseudo (null = aucun) */
  equippedTitleId       String?         @map("equipped_title_id")
  /** Charges bonus XP boutique (consommées à chaque quête validée) */
  xpBonusCharges        Int             @default(0) @map("xp_bonus_charges")
  /** Rappel push (app mobile) pour la quête du jour */
  reminderPushEnabled   Boolean         @default(false) @map("reminder_push_enabled")
  /** Rappel par e-mail */
  reminderEmailEnabled  Boolean         @default(false) @map("reminder_email_enabled")
  /** Heure locale du rappel : minutes depuis minuit (0–1439), ex. 540 = 9h00 */
  reminderTimeMinutes   Int             @default(540) @map("reminder_time_minutes")
  /** Fuseau IANA (ex. Europe/Paris) — horaire du rappel */
  reminderTimezone      String          @default("Europe/Paris") @map("reminder_timezone")
  /** Fréquence des rappels : daily | weekly | monthly (push + e-mail) */
  reminderCadence       String          @default("daily") @map("reminder_cadence")
  /** Dernière date (UTC YYYY-MM-DD) où un rappel push a été envoyé */
  lastReminderPushDate  String?         @map("last_reminder_push_date")
  /** Dernière date (UTC YYYY-MM-DD) où un rappel e-mail a été envoyé */
  lastReminderEmailDate String?         @map("last_reminder_email_date")
  /** Durée minimale souhaitée (minutes) — filtre archétypes + consigne LLM */
  questDurationMinMinutes Int           @default(5) @map("quest_duration_min_minutes")
  /** Durée maximale souhaitée (minutes) — filtre archétypes + consigne LLM */
  questDurationMaxMinutes Int           @default(1440) @map("quest_duration_max_minutes")
  /** Fréquence des quêtes « déplacement / à organiser » : low | balanced | high */
  heavyQuestPreference  String          @default("balanced") @map("heavy_quest_preference")
  /** Réponses questionnaire raffinement profil (ids question → id option) */
  refinementAnswers       Json          @default("{}") @map("refinement_answers")
  /** Dernière version du schéma de questionnaire complétée (0 = jamais) */
  refinementSchemaVersion Int           @default(0) @map("refinement_schema_version")
  refinementCompletedAt   DateTime?     @map("refinement_completed_at")
  /** Dernière date « plus tard » (YYYY-MM-DD) pour cooldown */
  refinementSkippedAt     String?       @map("refinement_skipped_at")
  /** Consentement explicite au traitement de ces préférences (RGPD) */
  refinementConsentAt     DateTime?     @map("refinement_consent_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  questLogs QuestLog[]
  shopTransactions ShopTransaction[]
  pushDevices PushDevice[]

  @@map("profiles")
}

model PushDevice {
  id              String   @id @default(cuid())
  profileId       String   @map("profile_id")
  /** Jeton Expo Push (ExponentPushToken[...]) */
  expoPushToken   String   @unique @map("expo_push_token")
  platform        String?  @map("platform")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("push_devices")
}

enum ShopTransactionStatus {
  pending
  paid
  failed
  refunded
}

/** Historique : anciens paiements Stripe directs, recharge coins, ou dépôts en coins */
enum WalletEntryKind {
  legacy_stripe_product
  stripe_coin_topup
  coin_purchase
}

model ShopTransaction {
  id                    String   @id @default(cuid())
  profileId             String   @map("profile_id")
  entryKind             WalletEntryKind @default(legacy_stripe_product) @map("entry_kind")
  /** Variation de solde en coins (+ recharge, − achat). Null pour anciennes lignes. */
  coinsDelta            Int?     @map("coins_delta")
  coinBalanceAfter      Int?     @map("coin_balance_after")
  stripeCheckoutSessionId String? @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId String?  @unique @map("stripe_payment_intent_id")
  /** Montant EUR (centimes) pour recharge Stripe ; 0 pour achat en coins */
  amountCents           Int      @default(0) @map("amount_cents")
  currency              String   @default("eur")
  status                ShopTransactionStatus @default(pending)
  primarySku            String   @map("primary_sku")
  label                 String
  lineItems             Json?    @map("line_items")
  createdAt             DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("shop_transactions")
}

model QuestLog {
  id          String      @id @default(cuid())
  profileId   String      @map("profile_id")
  questDate   String      @map("quest_date") // YYYY-MM-DD

  // Archetype reference
  archetypeId Int         @default(1) @map("archetype_id")

  // AI-generated content (unique per user per day)
  generatedEmoji      String   @default("⚔️") @map("generated_emoji")
  generatedTitle      String   @default("") @map("generated_title")
  generatedMission    String   @default("") @map("generated_mission") @db.Text
  generatedHook       String   @default("") @map("generated_hook")
  generatedDuration   String   @default("") @map("generated_duration")
  generatedSafetyNote String?  @map("generated_safety_note")
  isOutdoor           Boolean  @default(false) @map("is_outdoor")

  // Lieu suggéré (extérieur) — géocodage au moment de la génération
  destinationLabel    String?  @map("destination_label")
  destinationLat        Float?   @map("destination_lat")
  destinationLon      Float?   @map("destination_lon")

  // Context at generation time
  locationCity        String?  @map("location_city")
  weatherDescription  String?  @map("weather_description")
  weatherTemp         Float?   @map("weather_temp")

  // Status
  status            QuestStatus     @default(pending)
  /** Identifiant public de partage (lien unique web/mobile). */
  shareId           String?         @unique @map("share_id")
  completedAt       DateTime?       @map("completed_at")
  safetyConsentGiven Boolean        @default(false) @map("safety_consent_given")
  wasRerolled       Boolean         @default(false) @map("was_rerolled")
  wasFallback       Boolean         @default(false) @map("was_fallback")
  xpAwarded         Int?            @map("xp_awarded")
  xpBreakdown       Json?           @map("xp_breakdown")

  // Snapshot of profile state at quest time
  phaseAtAssignment     EscalationPhase @default(calibration) @map("phase_at_assignment")
  congruenceDeltaAtTime Float           @default(0) @map("congruence_delta_at_time")

  assignedAt DateTime @default(now()) @map("assigned_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, questDate])
  @@index([questDate])
  @@map("quest_logs")
}
