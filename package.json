{
  "name": "questia",
  "private": true,
  "main": "./apps/mobile/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/souProjet/Questia.git"
  },
  "bugs": {
    "url": "https://github.com/souProjet/Questia/issues"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-expo-web-browser-config.mjs",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@questia/web",
    "dev:mobile": "turbo dev --filter=@questia/mobile",
    "expo:start": "expo start apps/mobile",
    "mobile:android:bundle": "npm run android:bundle -w @questia/mobile",
    "android:assemble:win": "powershell -ExecutionPolicy Bypass -NoProfile -File scripts/win-android-assemble.ps1",
    "eas:android": "cd apps/mobile && eas build --platform android",
    "eas:ios": "cd apps/mobile && eas build --platform ios",
    "expo:android": "expo start apps/mobile --android",
    "expo:ios": "expo start apps/mobile --ios",
    "dev:mobile:clear": "npm run dev -w @questia/mobile -- --clear",
    "dev:mobile:tunnel": "npm run dev:tunnel -w @questia/mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "vitest run && npm run test -w @questia/mobile",
    "test:coverage": "vitest run --coverage && npm run test -w @questia/mobile",
    "test:mobile": "npm run test -w @questia/mobile",
    "ci": "npm run lint && npm run type-check && npm run test:coverage && npm run build",
    "test:e2e": "npm run test:e2e -w @questia/web",
    "test:e2e:local": "npm run test:e2e:local -w @questia/web",
    "clean": "turbo clean",
    "generate:logo": "node scripts/generate-questia-logo-square.mjs",
    "square-icon:512": "node scripts/square-icon-512.mjs",
    "icon:safe-zone": "node scripts/pad-app-icon-safe-zone.mjs",
    "clerk:redirect-urls": "node scripts/clerk-register-all-redirect-urls.mjs",
    "clerk:add-redirect-url": "node scripts/clerk-add-redirect-url.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "expo": "~54.0.33",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.5",
    "sharp": "^0.34.5",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.5"
  },
  "overrides": {
    "is-arrayish": "^0.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20"
  },
  "version": "1.0.0"
}
