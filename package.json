{
  "name": "dopamode",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@dopamode/web",
    "dev:mobile": "turbo dev --filter=@dopamode/mobile",
    "dev:mobile:tunnel": "npm run dev:tunnel -w @dopamode/mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20"
  }
}
